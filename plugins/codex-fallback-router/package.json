{
  "name": "codex-fallback-router",
  "version": "0.2.2",
  "description": "Local usage-limit fallback router for Codex Desktop",
  "type": "module",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "codex-fallback": "dist/cli.mjs"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && npm run typecheck && npm run test:unit && npm run test:integration && npm run test:secret-scan",
    "test:unit": "tsx --test tests/unit/**/*.test.ts",
    "test:integration": "tsx --test tests/integration/**/*.test.ts",
    "test:install": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File scripts/test-install-roundtrip.ps1",
    "test:secret-scan": "node scripts/scan-secrets.mjs --self-test",
    "secret-scan": "node scripts/scan-secrets.mjs --all"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
